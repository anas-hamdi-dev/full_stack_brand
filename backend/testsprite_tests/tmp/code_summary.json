{
  "tech_stack": [
    "Node.js",
    "Express.js",
    "MongoDB",
    "Mongoose",
    "JWT",
    "bcrypt",
    "Brevo (Sendinblue)",
    "Joi",
    "CORS"
  ],
  "features": [
    {
      "name": "Authentication API",
      "description": "User authentication endpoints including signup, signin, signout, email verification, and user profile retrieval",
      "files": [
        "routes/auth.js",
        "middleware/auth.js",
        "models/User.js",
        "utils/emailService.js"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "Authentication API",
          "version": "1.0.0"
        },
        "paths": {
          "/api/auth/signup": {
            "post": {
              "summary": "Register a new user",
              "requestBody": {
                "required": true,
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "required": ["email", "password", "phone", "role"],
                      "properties": {
                        "email": { "type": "string" },
                        "password": { "type": "string", "minLength": 6 },
                        "full_name": { "type": "string" },
                        "phone": { "type": "string" },
                        "role": { "type": "string", "enum": ["client", "brand_owner"] }
                      }
                    }
                  }
                }
              },
              "responses": {
                "201": { "description": "User created successfully" },
                "400": { "description": "Validation error" },
                "409": { "description": "User already exists" }
              }
            }
          },
          "/api/auth/signin": {
            "post": {
              "summary": "Authenticate user and get JWT token",
              "requestBody": {
                "required": true,
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "required": ["email", "password"],
                      "properties": {
                        "email": { "type": "string" },
                        "password": { "type": "string" }
                      }
                    }
                  }
                }
              },
              "responses": {
                "200": { "description": "Authentication successful" },
                "401": { "description": "Invalid credentials" },
                "403": { "description": "Admin access denied" }
              }
            }
          },
          "/api/auth/signout": {
            "post": {
              "summary": "Sign out user",
              "security": [{"bearerAuth": []}],
              "responses": {
                "200": { "description": "Sign out successful" }
              }
            }
          },
          "/api/auth/me": {
            "get": {
              "summary": "Get current authenticated user",
              "security": [{"bearerAuth": []}],
              "responses": {
                "200": { "description": "User information" }
              }
            }
          },
          "/api/auth/verify-email": {
            "post": {
              "summary": "Verify email with 6-digit code",
              "requestBody": {
                "required": true,
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "required": ["email", "verificationCode"],
                      "properties": {
                        "email": { "type": "string" },
                        "verificationCode": { "type": "string" }
                      }
                    }
                  }
                }
              },
              "responses": {
                "200": { "description": "Email verified successfully" },
                "400": { "description": "Invalid code or expired" },
                "429": { "description": "Too many attempts" }
              }
            }
          },
          "/api/auth/resend-verification": {
            "post": {
              "summary": "Resend email verification code",
              "requestBody": {
                "required": true,
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "required": ["email"],
                      "properties": {
                        "email": { "type": "string" }
                      }
                    }
                  }
                }
              },
              "responses": {
                "200": { "description": "Verification code sent" },
                "429": { "description": "Cooldown period active" }
              }
            }
          }
        }
      }
    },
    {
      "name": "User Management API",
      "description": "User profile management endpoints",
      "files": [
        "routes/users.js",
        "models/User.js",
        "middleware/auth.js"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "User Management API",
          "version": "1.0.0"
        },
        "paths": {
          "/api/users/me": {
            "patch": {
              "summary": "Update current user profile",
              "security": [{"bearerAuth": []}],
              "requestBody": {
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "full_name": { "type": "string" },
                        "phone": { "type": "string" }
                      }
                    }
                  }
                }
              },
              "responses": {
                "200": { "description": "Profile updated successfully" },
                "400": { "description": "Validation error" },
                "403": { "description": "Cannot change role or brand_id" }
              }
            }
          }
        }
      }
    },
    {
      "name": "Brands API",
      "description": "Brand management endpoints for listing, creating, updating brands with approval workflow",
      "files": [
        "routes/brands.js",
        "models/Brand.js",
        "middleware/auth.js",
        "middleware/authorization.js"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "Brands API",
          "version": "1.0.0"
        },
        "paths": {
          "/api/brands": {
            "get": {
              "summary": "Get all approved brands",
              "parameters": [
                { "name": "featured", "in": "query", "schema": { "type": "boolean" } },
                { "name": "search", "in": "query", "schema": { "type": "string" } },
                { "name": "limit", "in": "query", "schema": { "type": "integer" } }
              ],
              "responses": {
                "200": { "description": "List of approved brands" }
              }
            },
            "post": {
              "summary": "Create a new brand (brand owner only)",
              "security": [{"bearerAuth": []}],
              "requestBody": {
                "required": true,
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "required": ["name"],
                      "properties": {
                        "name": { "type": "string" },
                        "description": { "type": "string" },
                        "logo_url": { "type": "string" },
                        "location": { "type": "string" },
                        "website": { "type": "string" },
                        "instagram": { "type": "string" },
                        "facebook": { "type": "string" },
                        "phone": { "type": "string" },
                        "email": { "type": "string" }
                      }
                    }
                  }
                }
              },
              "responses": {
                "201": { "description": "Brand created successfully" },
                "409": { "description": "Brand name already exists or user already has a brand" }
              }
            }
          },
          "/api/brands/featured": {
            "get": {
              "summary": "Get all featured and approved brands",
              "responses": {
                "200": { "description": "List of featured brands" }
              }
            }
          },
          "/api/brands/me": {
            "get": {
              "summary": "Get brand owner's own brand",
              "security": [{"bearerAuth": []}],
              "responses": {
                "200": { "description": "Brand information" },
                "404": { "description": "Brand not found" }
              }
            }
          },
          "/api/brands/me/products": {
            "get": {
              "summary": "Get brand owner's own products",
              "security": [{"bearerAuth": []}],
              "responses": {
                "200": { "description": "List of products" }
              }
            }
          },
          "/api/brands/{id}": {
            "get": {
              "summary": "Get brand by ID",
              "parameters": [
                { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
              ],
              "responses": {
                "200": { "description": "Brand information" },
                "404": { "description": "Brand not found" }
              }
            },
            "patch": {
              "summary": "Update brand information",
              "security": [{"bearerAuth": []}],
              "parameters": [
                { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
              ],
              "requestBody": {
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "name": { "type": "string" },
                        "description": { "type": "string" },
                        "logo_url": { "type": "string" },
                        "location": { "type": "string" },
                        "website": { "type": "string" },
                        "instagram": { "type": "string" },
                        "facebook": { "type": "string" },
                        "phone": { "type": "string" },
                        "email": { "type": "string" }
                      }
                    }
                  }
                }
              },
              "responses": {
                "200": { "description": "Brand updated successfully" },
                "403": { "description": "Cannot change status" }
              }
            }
          },
          "/api/brands/{brandId}/products": {
            "get": {
              "summary": "Get products for a specific brand",
              "parameters": [
                { "name": "brandId", "in": "path", "required": true, "schema": { "type": "string" } }
              ],
              "responses": {
                "200": { "description": "List of products" },
                "404": { "description": "Brand not found" }
              }
            }
          }
        }
      }
    },
    {
      "name": "Products API",
      "description": "Product management endpoints for listing, creating, updating, and deleting products",
      "files": [
        "routes/products.js",
        "models/Product.js",
        "models/Brand.js",
        "middleware/auth.js",
        "middleware/authorization.js"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "Products API",
          "version": "1.0.0"
        },
        "paths": {
          "/api/products": {
            "get": {
              "summary": "Get all products from approved brands",
              "parameters": [
                { "name": "brand_id", "in": "query", "schema": { "type": "string" } },
                { "name": "search", "in": "query", "schema": { "type": "string" } },
                { "name": "limit", "in": "query", "schema": { "type": "integer" } }
              ],
              "responses": {
                "200": { "description": "List of products" }
              }
            },
            "post": {
              "summary": "Create a new product (brand owner with approved brand only)",
              "security": [{"bearerAuth": []}],
              "requestBody": {
                "required": true,
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "required": ["name", "price", "images"],
                      "properties": {
                        "name": { "type": "string" },
                        "description": { "type": "string" },
                        "price": { "type": "number", "minimum": 0 },
                        "images": {
                          "type": "array",
                          "items": { "type": "string" },
                          "minItems": 1
                        },
                        "purchaseLink": { "type": "string" }
                      }
                    }
                  }
                }
              },
              "responses": {
                "201": { "description": "Product created successfully" },
                "400": { "description": "Validation error" },
                "403": { "description": "Brand not approved" }
              }
            }
          },
          "/api/products/{id}": {
            "get": {
              "summary": "Get product by ID",
              "parameters": [
                { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
              ],
              "responses": {
                "200": { "description": "Product information" },
                "404": { "description": "Product not found" }
              }
            },
            "patch": {
              "summary": "Update product information",
              "security": [{"bearerAuth": []}],
              "parameters": [
                { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
              ],
              "requestBody": {
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "required": ["price"],
                      "properties": {
                        "name": { "type": "string" },
                        "description": { "type": "string" },
                        "price": { "type": "number", "minimum": 0 },
                        "images": {
                          "type": "array",
                          "items": { "type": "string" },
                          "minItems": 1
                        },
                        "purchaseLink": { "type": "string" }
                      }
                    }
                  }
                }
              },
              "responses": {
                "200": { "description": "Product updated successfully" },
                "403": { "description": "Access denied" }
              }
            },
            "delete": {
              "summary": "Delete a product",
              "security": [{"bearerAuth": []}],
              "parameters": [
                { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
              ],
              "responses": {
                "200": { "description": "Product deleted successfully" },
                "403": { "description": "Access denied" }
              }
            }
          }
        }
      }
    },
    {
      "name": "Favorites API",
      "description": "Client favorites management endpoints for adding, removing, and checking favorite products",
      "files": [
        "routes/favorites.js",
        "models/Favorite.js",
        "models/Product.js",
        "middleware/auth.js",
        "middleware/authorization.js"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "Favorites API",
          "version": "1.0.0"
        },
        "paths": {
          "/api/favorites": {
            "get": {
              "summary": "Get user's favorite products",
              "security": [{"bearerAuth": []}],
              "responses": {
                "200": { "description": "List of favorite products" }
              }
            },
            "post": {
              "summary": "Add product to favorites",
              "security": [{"bearerAuth": []}],
              "requestBody": {
                "required": true,
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "required": ["product_id"],
                      "properties": {
                        "product_id": { "type": "string" }
                      }
                    }
                  }
                }
              },
              "responses": {
                "201": { "description": "Product added to favorites" },
                "409": { "description": "Product already in favorites" }
              }
            }
          },
          "/api/favorites/{productId}": {
            "delete": {
              "summary": "Remove product from favorites",
              "security": [{"bearerAuth": []}],
              "parameters": [
                { "name": "productId", "in": "path", "required": true, "schema": { "type": "string" } }
              ],
              "responses": {
                "200": { "description": "Product removed from favorites" },
                "404": { "description": "Favorite not found" }
              }
            }
          },
          "/api/favorites/check/{productId}": {
            "get": {
              "summary": "Check if product is favorited",
              "security": [{"bearerAuth": []}],
              "parameters": [
                { "name": "productId", "in": "path", "required": true, "schema": { "type": "string" } }
              ],
              "responses": {
                "200": { "description": "Favorite status" }
              }
            }
          }
        }
      }
    },
    {
      "name": "Contact Messages API",
