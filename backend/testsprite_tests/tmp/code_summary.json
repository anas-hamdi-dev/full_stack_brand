                        "name": { "type": "string" },
                        "email": { "type": "string" },
                        "subject": { "type": "string" },
                        "message": { "type": "string" }
                      }
                    }
                  }
                }
              },
              "responses": {
                "201": { "description": "Contact message created successfully" },
                "400": { "description": "Validation error" }
              }
            }
          }
        }
      }
    },
    {
      "name": "Health Check API",
      "description": "API health and database status endpoint",
      "files": [
        "server.js",
        "config/database.js"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "Health Check API",
          "version": "1.0.0"
        },
        "paths": {
          "/api/health": {
            "get": {
              "summary": "Check API and database health",
              "responses": {
                "200": { "description": "Service is healthy" },
                "503": { "description": "Service is degraded" }
              }
            }
          }
        }
      }
    }
  ]
}

